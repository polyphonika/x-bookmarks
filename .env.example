# X (Twitter) API — OAuth 2.0 user-context (PKCE).
# Create an app at https://developer.x.com, set redirect URI to:
#   http://localhost:8765/callback
# Required scopes (set on the app): tweet.read users.read bookmark.read offline.access
X_CLIENT_ID=
X_CLIENT_SECRET=

# Anthropic API — for topic classification.
ANTHROPIC_API_KEY=

# Google Sheets — service account JSON path + the target sheet ID.
# 1. Create a service account in Google Cloud, download its JSON key as
#    google_credentials.json (kept out of git via .gitignore).
# 2. Create a blank Google Sheet, copy the long ID from the URL.
# 3. Share the sheet with the service account email (...@...iam.gserviceaccount.com).
GOOGLE_SERVICE_ACCOUNT_FILE=google_credentials.json
GOOGLE_SHEET_ID=
